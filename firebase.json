{
  "hosting": {
    "public": "firebase-hosting",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      {
        "source": "/",
        "destination": "https://quackforge.vercel.app/",
        "type": 302
      },
      {
        "source": "/:path*",
        "destination": "https://quackforge.vercel.app/:path*",
        "type": 302
      }
    ]
  }
}
